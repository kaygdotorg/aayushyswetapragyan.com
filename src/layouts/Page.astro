---
import Base from './Base.astro';
import { site } from '../data/site';

interface Props {
  frontmatter?: {
    title?: string;
    description?: string;
    intro?: string;
    updated?: string;
  };
  // Allow direct use (non-markdown) too.
  title?: string;
  description?: string;
  intro?: string;
  updated?: string;
}

const fm = Astro.props.frontmatter ?? Astro.props;
const { title, description, intro, updated } = fm;
const pageTitle = title ? `${title} · ${site.title}` : site.title;
---

<Base title={pageTitle} description={description}>
  <article class="page wrap">
    <header class="page__head">
      <p class="eyebrow" data-reveal>Aayushy Swetapragyan</p>
      <h1 class="page__title" data-reveal style="--reveal-delay: 80ms">{title}</h1>
      {intro && <p class="page__intro" data-reveal style="--reveal-delay: 160ms">{intro}</p>}
      {updated && <p class="page__updated" data-reveal style="--reveal-delay: 200ms">Last updated {updated}</p>}
    </header>

    <div class="prose" data-reveal style="--reveal-delay: 120ms">
      <slot />
    </div>
  </article>
</Base>

<style>
  .page {
    max-width: 720px;
    padding-top: clamp(0.5rem, 3vw, 2rem);
  }
  .page__head { margin-bottom: clamp(2rem, 5vw, 3rem); }
  .page__title { margin-top: 0.5rem; }
  .page__intro {
    margin-top: 1.25rem;
    font-size: var(--step-1);
    color: var(--espresso-soft);
    max-width: 52ch;
  }
  .page__updated {
    margin-top: 1rem;
    font-size: var(--step--1);
    color: var(--sage);
    font-weight: 540;
  }

  /* prose styles for markdown content */
  .prose :global(h2) {
    font-size: var(--step-2);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-size: var(--step-1);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) {
    margin-bottom: 1.1rem;
    color: var(--espresso);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.3rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose :global(li) { padding-left: 0.25rem; }
  .prose :global(li::marker) { color: var(--terracotta); }
  .prose :global(a) {
    text-decoration: underline;
    text-decoration-color: var(--sand);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.3s var(--ease);
  }
  .prose :global(a:hover) { text-decoration-color: var(--terracotta); }
  .prose :global(strong) { color: var(--espresso); font-weight: 600; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }
  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    border-left: 3px solid var(--sand);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--step-1);
    color: var(--espresso-soft);
  }
  .prose :global(code) {
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 0.88em;
    background: var(--cream-deep);
    padding: 0.15em 0.4em;
    border-radius: 6px;
  }
</style>
