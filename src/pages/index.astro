---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { site } from '../data/site';
import portrait from '../assets/aayushy.jpg';
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="hero wrap">
    <div class="hero__text">
      <p class="eyebrow" data-reveal>my small, warm corner of the internet</p>

      <h1 class="hero__name" data-reveal style="--reveal-delay: 80ms">
        Hi, I&rsquo;m <span class="hero__given">Aayushy Swetapragyan</span><span class="hero__dot">.</span>
      </h1>

      <ul class="hero__roles" data-reveal style="--reveal-delay: 160ms" aria-label="What I do">
        {site.roles.map((r) => <li>{r}</li>)}
      </ul>

      <p class="hero__lede" data-reveal style="--reveal-delay: 240ms">
        Psychologist by training, photographer by heart, and an operations
        specialist by day. This is where I keep my photographs, my thoughts,
        and the little things I&rsquo;m loving lately.
      </p>

      <div class="hero__cta" data-reveal style="--reveal-delay: 320ms">
        <a class="btn btn--solid" href="/now">What I&rsquo;m up to now <span aria-hidden="true">&rarr;</span></a>
        <a class="btn btn--ghost" href="/uses">Things I use</a>
      </div>
    </div>

    <div class="hero__media" data-reveal style="--reveal-delay: 200ms">
      <figure class="frame">
        <!-- Optimised at build time by Astro (resize + AVIF/WebP). Swap the import
             at the top of this file to use a different photo. -->
        <Image
          src={portrait}
          alt="Aayushy Swetapragyan"
          width={480}
          height={480}
          densities={[1, 2]}
          format="webp"
          quality={72}
          loading="eager"
          fetchpriority="high"
        />
      </figure>
      <span class="sticker" aria-hidden="true">hello ✿</span>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section class="band wrap" aria-labelledby="about-title">
    <p class="eyebrow" data-reveal>a little about me</p>
    <h2 id="about-title" class="band__title" data-reveal style="--reveal-delay: 80ms">
      Loud, inappropriate, on the hunt for conversations and portraits
    </h2>
    <p class="band__body" data-reveal style="--reveal-delay: 160ms">
      I spend my days untangling how people work and helping them run a little
      smoother. Off the clock, you&rsquo;ll usually find me chasing people I love 
      with my camera, getting lost in a good book, or thinking about what would make me more money.
    </p>
  </section>

  <!-- ===================== NOW & USES ===================== -->
  <section class="cards wrap" aria-label="Explore">
    <a href="/now" class="card" data-reveal>
      <span class="card__kicker">/now</span>
      <h3 class="card__title">What I&rsquo;m doing now</h3>
      <p class="card__desc">The current season: what I&rsquo;m making, reading, and focused on this month.</p>
      <span class="card__go">Take a peek <span aria-hidden="true">&rarr;</span></span>
    </a>
    <a href="/uses" class="card card--alt" data-reveal style="--reveal-delay: 120ms">
      <span class="card__kicker">/uses</span>
      <h3 class="card__title">Things I use &amp; love</h3>
      <p class="card__desc">The gear, apps, and everyday objects that earn their place in my life.</p>
      <span class="card__go">See the list <span aria-hidden="true">&rarr;</span></span>
    </a>
  </section>

  <!-- ===================== CONTACT ===================== -->
  <section class="contact wrap" aria-labelledby="contact-title">
    <div class="contact__inner" data-reveal>
      <h2 id="contact-title" class="contact__title">Say hello</h2>
      <p class="contact__body">
        Looking to hire? Here&rsquo;s my <a class="pill-link" href="/resume.pdf" target="_blank" rel="noopener">resume</a>.
        My inbox is always open.
      </p>
      <a class="btn btn--solid" href={`mailto:${site.email}`}>{site.email}</a>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-top: clamp(0.5rem, 3vw, 2rem);
    padding-bottom: clamp(3rem, 9vw, 7rem);
  }
  .hero__name {
    margin-top: 0.5rem;
    font-weight: 600;
  }
  .hero__given {
    font-style: italic;
    color: var(--terracotta-deep);
  }
  .hero__dot { color: var(--sage); }

  .hero__roles {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    list-style: none;
    margin-top: 1.25rem;
  }
  .hero__roles li {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: 0.03em;
    color: var(--espresso-soft);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35em 0.9em;
  }

  .hero__lede {
    margin-top: 1.5rem;
    max-width: 46ch;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--espresso-soft);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  /* photo frame */
  .hero__media { position: relative; justify-self: center; width: 100%; }
  .frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--card);
    rotate: 1.4deg;
    transition: rotate 0.6s var(--ease), box-shadow 0.6s var(--ease);
  }
  .frame::after {
    /* thin inner border for a printed-photo feel */
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: inherit;
    pointer-events: none;
  }
  .frame img { display: block; width: 100%; height: auto; }
  .hero__media:hover .frame { rotate: 0deg; box-shadow: var(--shadow-soft); }

  .sticker {
    position: absolute;
    bottom: -0.9rem;
    left: -0.9rem;
    background: var(--sage);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    padding: 0.5em 1em;
    border-radius: 999px;
    rotate: -4deg;
    box-shadow: var(--shadow);
  }

  /* ---------- ABOUT ---------- */
  .band {
    padding-block: clamp(3rem, 8vw, 6rem);
    max-width: 880px;
  }
  .band__title {
    margin-top: 0.75rem;
    max-width: 18ch;
  }
  .band__body {
    margin-top: 1.5rem;
    max-width: 60ch;
    font-size: var(--step-1);
    color: var(--espresso-soft);
  }
  .band__body em { color: var(--espresso); font-style: italic; }

  /* ---------- NOW & USES CARDS ---------- */
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.25rem, 3vw, 2rem);
    padding-block: clamp(1rem, 4vw, 2rem);
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-lg);
    background: var(--card);
    border: 1px solid var(--line);
    color: var(--espresso);
    box-shadow: var(--shadow);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .card--alt { background: var(--cream-deep); }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: var(--sand);
  }
  .card__kicker {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--terracotta-deep);
  }
  .card__title { font-size: var(--step-2); margin-top: 0.25rem; }
  .card__desc { color: var(--espresso-soft); max-width: 38ch; }
  .card__go {
    margin-top: 0.5rem;
    font-weight: 560;
    font-size: var(--step--1);
    color: var(--espresso);
  }
  .card__go span { display: inline-block; transition: transform 0.3s var(--ease); }
  .card:hover .card__go span { transform: translateX(5px); }

  /* ---------- CONTACT ---------- */
  .contact { padding-block: clamp(3rem, 8vw, 6rem); }
  .contact__inner {
    text-align: center;
    background:
      radial-gradient(70% 120% at 50% 0%, rgba(232, 201, 160, 0.45), transparent 70%),
      var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 5vw, 3rem);
    box-shadow: var(--shadow);
  }
  .contact__title { font-size: var(--step-3); }
  .contact__body {
    margin: 1rem auto 2rem;
    max-width: 42ch;
    color: var(--espresso-soft);
    font-size: var(--step-1);
  }

  /* shiny little pill link (e.g. "resume") */
  .pill-link {
    display: inline-block;
    padding: 0.08em 0.7em;
    margin-inline: 0.12em;
    border-radius: 999px;
    font-size: 0.86em;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    background: linear-gradient(135deg, #e08a5d 0%, var(--terracotta) 45%, var(--terracotta-deep) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.45),
      0 2px 8px -2px rgba(164, 74, 38, 0.5);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), filter 0.3s var(--ease);
  }
  .pill-link:hover {
    transform: translateY(-1px);
    filter: brightness(1.06) saturate(1.05);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      0 5px 16px -3px rgba(164, 74, 38, 0.6);
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .hero__media {
      order: -1;
      max-width: 360px;
      margin-inline: auto;
    }
    .cards { grid-template-columns: 1fr; }
  }
</style>
