---
export const prerender = true;
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base title={`Lost page · ${site.title}`} description="This page wandered off, but the way home is just a click away.">
  <section class="oops wrap">
    <div class="oops__inner" data-reveal>
      <p class="eyebrow">a little detour</p>

      <p class="oops__code" aria-hidden="true">
        4<span class="oops__o">0</span>4
      </p>

      <h1 class="oops__title">This page wandered off.</h1>

      <p class="oops__lede">
        The link might be old, or the page packed up and moved. Either way,
        let&rsquo;s find you something lovelier to look at.
      </p>

      <div class="oops__cta">
        <a class="btn btn--solid" href="/">Back home <span aria-hidden="true">&rarr;</span></a>
        <a class="btn btn--ghost" href="/now">What I&rsquo;m up to now</a>
      </div>

      <span class="sticker" aria-hidden="true">oops ✿</span>
    </div>
  </section>
</Base>

<style>
  .oops {
    display: grid;
    place-items: center;
    min-height: clamp(52vh, 60vh, 70vh);
    padding-block: clamp(2.5rem, 8vw, 6rem);
  }
  .oops__inner {
    position: relative;
    text-align: center;
    max-width: 46ch;
  }

  .oops__code {
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 0.9;
    font-size: clamp(5.5rem, 4rem + 14vw, 12rem);
    color: var(--espresso);
    margin-top: 0.75rem;
    letter-spacing: -0.02em;
  }
  /* the middle "0" gets the terracotta accent + a gentle, breathing tilt */
  .oops__o {
    display: inline-block;
    font-style: italic;
    color: var(--terracotta-deep);
    animation: drift 6s var(--ease) infinite;
  }
  @keyframes drift {
    0%, 100% { transform: rotate(-5deg) translateY(0); }
    50% { transform: rotate(5deg) translateY(-0.06em); }
  }

  .oops__title {
    margin-top: 0.5rem;
    font-size: var(--step-3);
  }
  .oops__lede {
    margin: 1.25rem auto 0;
    max-width: 40ch;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--espresso-soft);
  }

  .oops__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
    margin-top: 2.25rem;
  }

  /* warm little sticker, echoing the home hero */
  .sticker {
    position: absolute;
    top: -1.1rem;
    right: 0.25rem;
    background: var(--sage);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    padding: 0.5em 1em;
    border-radius: 999px;
    rotate: 5deg;
    box-shadow: var(--shadow);
  }

  @media (prefers-reduced-motion: reduce) {
    .oops__o { animation: none; transform: rotate(-4deg); }
  }

  @media (max-width: 560px) {
    .sticker { top: -0.6rem; right: auto; left: 50%; translate: -50% 0; }
  }
</style>
