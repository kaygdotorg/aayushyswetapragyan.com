---
export const prerender = true;
import { getEntry, render } from 'astro:content';
import Page from '../layouts/Page.astro';
import UsesGallery from '../components/UsesGallery.astro';

const entry = await getEntry('uses', 'index');
const { Content } = await render(entry!);
---

<Page
  title="Uses"
  description="The gear, apps, and everyday things Aayushy Swetapragyan uses and loves."
  intro={entry!.data.intro}
  updated={entry!.data.updated}
>
  <Content components={{ Gallery: UsesGallery }} />

  <hr />

  <p><em>Inspired by the <a href="https://uses.tech/">/uses page</a> community.</em></p>
</Page>
