---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Writing · Aayushy Swetapragyan" description="Notes and writing by Aayushy Swetapragyan.">
  <section class="writing wrap">
    <header class="writing__head">
      <p class="eyebrow" data-reveal>Aayushy Swetapragyan</p>
      <h1 class="writing__title" data-reveal style="--reveal-delay: 80ms">Writing</h1>
    </header>

    {
      posts.length === 0 ? (
        <p class="writing__empty" data-reveal>Nothing here yet.</p>
      ) : (
        <ul class="writing__list">
          {posts.map((post) => (
            <li class="writing__item" data-reveal>
              <a href={`/writing/${post.id.replace(/\/index$/, '')}`}>
                <time class="writing__date">{fmt(post.data.date)}</time>
                <h2 class="writing__post-title">{post.data.title}</h2>
                {post.data.description && <p class="writing__desc">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>

<style>
  .writing { max-width: 720px; padding-top: clamp(0.5rem, 3vw, 2rem); }
  .writing__head { margin-bottom: clamp(2rem, 5vw, 3rem); }
  .writing__title { margin-top: 0.5rem; }
  .writing__list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  .writing__item a {
    display: block;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--card);
    color: var(--espresso);
    box-shadow: var(--shadow);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .writing__item a:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
    border-color: var(--sand);
  }
  .writing__date {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--terracotta-deep);
    font-weight: 600;
  }
  .writing__post-title { font-size: var(--step-2); margin-top: 0.2rem; }
  .writing__desc { margin-top: 0.4rem; color: var(--espresso-soft); }
  .writing__empty { color: var(--espresso-soft); }
</style>
