---
import { Image } from 'astro:assets';

// Auto-includes every image in src/assets/uses/ — drop a new photo in there
// and it shows up here (sorted by filename). Optimised at build time.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/uses/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const images = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const slug = path.split('/').pop()!.replace(/\.[a-z]+$/i, '');
    const alt = slug.replace(/[-_]+/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    return { src: mod.default, alt };
  });
---

{
  images.length > 0 && (
    <div class="gallery" role="list" aria-label="A few of my things">
      {images.map((img) => (
        <figure class="gallery__item" role="listitem">
          <Image
            src={img.src}
            alt={img.alt}
            width={320}
            height={400}
            densities={[1, 2]}
            format="webp"
            quality={72}
            loading="lazy"
          />
        </figure>
      ))}
    </div>
  )
}

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.9rem;
    margin-top: 1.25rem;
  }
  .gallery__item {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--cream-deep);
  }
  .gallery__item :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .gallery__item:hover :global(img) {
    transform: scale(1.04);
  }
</style>
